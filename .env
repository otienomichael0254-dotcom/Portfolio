# ─────────────────────────────────────────────────────────────
#  EmailJS Credentials
#  Source: https://dashboard.emailjs.com
#  Mirror all values into emailjs.config.js for browser use.
# ─────────────────────────────────────────────────────────────

# Public Key → Account > API Keys
EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY

# Service ID → Email Services > your service > Service ID
EMAILJS_SERVICE_ID=YOUR_SERVICE_ID

# Notification Template ID (email sent TO YOU)
# Variables used: from_name, from_email, reply_to,
#                 company, project_type, budget, message
EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID

# Auto-Reply Template ID (email sent TO THE VISITOR)
# Variables used: to_name, to_email, from_name, reply_to,
#                 from_name_full, company, project_type, budget, message
EMAILJS_AUTOREPLY_TEMPLATE_ID=YOUR_AUTOREPLY_TEMPLATE_ID

# ─────────────────────────────────────────────────────────────
#  NOTE: Plain HTML projects cannot read .env at runtime.
#  Paste your real values into emailjs.config.js as well.
#  Never commit real API keys to public version control.
# ─────────────────────────────────────────────────────────────
