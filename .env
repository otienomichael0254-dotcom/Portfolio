# ─────────────────────────────────────────────────────────────
#  EmailJS Configuration
#  Obtain these values from https://dashboard.emailjs.com
# ─────────────────────────────────────────────────────────────

# Your EmailJS Public Key  →  Account > API Keys
EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY

# Service ID of your connected email provider (Gmail, Outlook, etc.)
# Found under:  Email Services > your service > Service ID
EMAILJS_SERVICE_ID=YOUR_SERVICE_ID

# Template ID – notification email sent TO YOU when a visitor submits
# Found under:  Email Templates > your template > Template ID
EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID

# Template ID – auto-reply sent BACK TO THE VISITOR confirming receipt
EMAILJS_AUTOREPLY_TEMPLATE_ID=YOUR_AUTOREPLY_TEMPLATE_ID

# ─────────────────────────────────────────────────────────────
#  NOTE: Plain HTML projects cannot read .env at runtime.
#  Copy your real values into emailjs.config.js as well.
#  Never commit real keys to public version control.
# ─────────────────────────────────────────────────────────────
